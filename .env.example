# Banco de dados — use a Transaction String do Supabase
# Formato: postgresql://postgres.[ref]:[senha]@aws-0-[região].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Credenciais do painel administrativo
ADMIN_USER="admin"
ADMIN_PASS="sua_senha_segura_aqui"

# Secret para assinatura dos tokens JWT (gere com: openssl rand -base64 32)
JWT_SECRET="seu_secret_jwt_seguro_aqui"
